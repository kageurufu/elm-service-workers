{
    "serve": "public",
    "postprocess": [
        "elm-watch-node",
        "postprocess.js"
    ],
    "targets": {
        "Frontend": {
            "inputs": [
                "src/Frontend.elm"
            ],
            "output": "public/build/Frontend.elm.js"
        },
        "Worker": {
            "inputs": [
                "src/Worker.elm"
            ],
            "output": "public/build/Worker.elm.js"
        }
    }
}